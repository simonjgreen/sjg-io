---
import Page from '../../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const bluhaloPage = await getCollection('pages', ({ id }) => id === 'work/bluhalo');
const bluhaloContent = bluhaloPage[0];

if (!bluhaloContent) {
  throw new Error('Bluhalo page content not found');
}

const { Content } = await render(bluhaloContent);
---

<Page 
  title={bluhaloContent.data.title} 
  description={bluhaloContent.data.description}
>
  <Content />
</Page>
