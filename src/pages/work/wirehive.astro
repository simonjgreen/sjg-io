---
import Page from '../../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const wirehivePage = await getCollection('pages', ({ id }) => id === 'work/wirehive');
const wirehiveContent = wirehivePage[0];

if (!wirehiveContent) {
  throw new Error('Wirehive page content not found');
}

const { Content } = await render(wirehiveContent);
---

<Page 
  title={wirehiveContent.data.title} 
  description={wirehiveContent.data.description}
>
  <Content />
</Page>
