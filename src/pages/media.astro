---
import Page from '../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const mediaPage = await getCollection('pages', ({ id }) => id === 'media');
const mediaContent = mediaPage[0];

if (!mediaContent) {
  throw new Error('Media page content not found');
}

const { Content } = await render(mediaContent);
---

<Page 
  title={mediaContent.data.title} 
  description={mediaContent.data.description}
>
  <Content />
</Page>
