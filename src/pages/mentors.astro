---
import Page from '../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const mentorsPage = await getCollection('pages', ({ id }) => id === 'mentors');
const mentorsContent = mentorsPage[0];

if (!mentorsContent) {
  throw new Error('Mentors page content not found');
}

const { Content } = await render(mentorsContent);
---

<Page 
  title={mentorsContent.data.title} 
  description={mentorsContent.data.description}
>
  <Content />
</Page>
