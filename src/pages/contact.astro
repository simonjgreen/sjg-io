---
import Page from '../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const contactPage = await getCollection('pages', ({ id }) => id === 'contact');
const contactContent = contactPage[0];

if (!contactContent) {
  throw new Error('Contact page content not found');
}

const { Content } = await render(contactContent);
---

<Page 
  title={contactContent.data.title} 
  description={contactContent.data.description}
>
  <Content />
</Page>
