---
import Page from '../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const colophonPage = await getCollection('pages', ({ id }) => id === 'colophon');
const colophonContent = colophonPage[0];

if (!colophonContent) {
  throw new Error('Colophon page content not found');
}

const { Content } = await render(colophonContent);
---

<Page 
  title={colophonContent.data.title} 
  description={colophonContent.data.description}
>
  <Content />
</Page>
