---
import Page from '../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const nowPage = await getCollection('pages', ({ id }) => id === 'now');
const nowContent = nowPage[0];

if (!nowContent) {
  throw new Error('Now page content not found');
}

const { Content } = await render(nowContent);
---

<Page 
  title={nowContent.data.title} 
  description={nowContent.data.description}
>
  <Content />
</Page>
